{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GraalSuite",
  "version": "0.1.3",
    "identifier": "com.morenoland.graalsuite",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:13772",
    "beforeDevCommand": "node server.js",
    "beforeBuildCommand": "node js/build-web.js"
  },
  "app": {
    "windows": [
      {
        "title": "GraalSuite",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRFOThCNzk2QjEyMUVEQUUKUldTdTdTR3hscmVZVGlDR2EybW1WN2JlWWRySnJVa1VNN0VTTFlnVzFxNmZUNlB6T2tLT2g3bmQK",
      "endpoints": ["https://github.com/MorenoLand/GScript.GraalSuite/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
