{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "GraalSuite",
  "version": "0.1.0",
    "identifier": "com.morenoland.graalsuite",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:13772",
    "beforeDevCommand": "node server.js",
    "beforeBuildCommand": "node js/build-web.js"
  },
  "app": {
    "windows": [
      {
        "title": "GraalSuite",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
